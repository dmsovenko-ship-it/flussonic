# === Flussonic Watcher API ===
FLUSSONIC_URL=http://172.20.1.21
FLUSSONIC_LOGIN=zabbix
FLUSSONIC_PASSWORD=your_password

# === Telegram ===
TG_TOKEN=your_bot_token
TG_API_URL=https://api.telegram.org

# Общий чат (fallback для всех типов)
TG_CHAT_ID=-1003470159173

# Раздельные чаты по типам событий (если не заданы — используется TG_CHAT_ID)
TG_CHAT_ID_FACE=-1002051599057
TG_CHAT_ID_PLATE=-1002051599057
TG_CHAT_ID_MOTION=-1003470159173

# === poll_watcher.py ===
EVENT_TYPES=face,plate,motion
CAMERA_FILTER=
POLL_INTERVAL=5
DOWNLOAD_MEDIA=true
RATE_LIMIT_SEC=10
RATE_LIMIT_COUNT=3
RATE_LIMIT_WINDOW=300
MAX_EVENT_AGE_HOURS=24
WEBHOOK_FWD_URL=http://localhost:8081
NOMEROGRAM_KEY=

# === webhook_receiver.py ===
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8081
DOWNLOAD_VIDEO=true
# EVENT_TYPES для webhook_receiver (пусто = все)
# Рекомендуется: face,motion (plate обрабатывает poll_watcher подробнее)

# === SMTP (опционально) ===
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_SUBJECT=Flussonic: движение {{ stream }}

# === Прокси (опционально) ===
PROXY_URL=

# === Логирование ===
LOG_LEVEL=INFO

# === HTTP-токен для webhook_receiver (опционально) ===
HTTP_TOKEN=
